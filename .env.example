# SpamGuard DW — environment template
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is safe to commit.

# ---- Anthropic (Ask AI text-to-SQL) ----
# Get a key at https://console.anthropic.com/
# If blank, the /api/ask endpoint falls back to the offline SQL router.
ANTHROPIC_API_KEY=

# Optional: override the Claude model (default: claude-haiku-4-5-20251001 — fast & cheap)
# ANTHROPIC_MODEL=claude-sonnet-4-6
